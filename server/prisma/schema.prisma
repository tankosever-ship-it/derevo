generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  maidenName   String?
  birthDate    String?
  birthPlace   String?
  deathDate    String?
  deathPlace   String?
  bio          String?
  gender       Gender   @default(UNKNOWN)
  isArchival   Boolean  @default(false)
  familyLine   String?  // for archival: which surname/line they might belong to
  archivalNote String?  // notes about archival connection
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  media              Media[]
  relationshipsAsA   Relationship[] @relation("PersonA")
  relationshipsAsB   Relationship[] @relation("PersonB")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model Relationship {
  id        Int          @id @default(autoincrement())
  personA   Person       @relation("PersonA", fields: [personAId], references: [id], onDelete: Cascade)
  personAId Int
  personB   Person       @relation("PersonB", fields: [personBId], references: [id], onDelete: Cascade)
  personBId Int
  type      RelationType

  @@unique([personAId, personBId, type])
}

enum RelationType {
  PARENT_OF
  SPOUSE_OF
}

model Media {
  id        Int       @id @default(autoincrement())
  filename  String
  url       String
  mimeType  String
  type      MediaType
  caption   String?
  person    Person    @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId  Int
  createdAt DateTime  @default(now())
}

enum MediaType {
  PHOTO
  DOCUMENT
}

model FamilyClan {
  id          Int           @id @default(autoincrement())
  name        String        @unique // surname/clan name e.g. "Коваленки"
  description String?
  origin      String?       // geographic origin
  period      String?       // time period e.g. "XIX-XX ст."
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  documents   ClanDocument[]
}

model ClanDocument {
  id        Int        @id @default(autoincrement())
  filename  String
  url       String
  mimeType  String
  caption   String?
  clan      FamilyClan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  clanId    Int
  createdAt DateTime   @default(now())
}
